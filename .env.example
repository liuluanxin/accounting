# ===================================================================
# 宇宙记账 - 环境配置模板
# 复制此文件为 .env 并根据需要修改
# ===================================================================

# 应用环境 (development / production)
NODE_ENV=development

# 日志级别 (DEBUG / INFO / WARN / ERROR / SILENT)
LOG_LEVEL=DEBUG

# ==================== API 配置 ====================

# 请求适配器: 'local' | 'http'
#   local - 使用本地存储模拟 API（开发/演示用，零依赖）
#   http  - 发送真实 HTTP 请求到后端服务（生产环境）
API_ADAPTER=local

# HTTP 模式下的后端 API 基础地址（仅 API_ADAPTER=http 时生效）
# API_BASE_URL=https://api.cosmic-accounting.example.com

# 请求超时（毫秒）
API_TIMEOUT=15000

# 认证令牌存储键名
AUTH_TOKEN_KEY=auth_token

# ==================== 应用元信息 ====================

APP_TITLE=宇宙记账
APP_VERSION=1.0.0
